{
  "npm": "@vtsls/language-server",
  "command": "node",
  "args": ["./node_modules/@vtsls/language-server/bin/vtsls.js", "--stdio"],
  "languages": {
    "typescript": [".ts", ".mts", ".cts"],
    "typescriptreact": [".tsx"],
    "javascript": [".js", ".mjs", ".cjs"],
    "javascriptreact": [".jsx"]
  },
  "transport": "stdio"
}
