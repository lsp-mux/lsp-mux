{
  "args": [
    "./node_modules/@vtsls/language-server/bin/vtsls.js",
    "--stdio"
  ],
  "command": "node",
  "languages": {
    "javascript": [
      ".js",
      ".mjs",
      ".cjs"
    ],
    "javascriptreact": [
      ".jsx"
    ],
    "typescript": [
      ".ts",
      ".mts",
      ".cts"
    ],
    "typescriptreact": [
      ".tsx"
    ]
  },
  "npm": "@vtsls/language-server",
  "transport": "stdio"
}
