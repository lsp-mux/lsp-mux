{
  "args": [
    "./node_modules/@lsp-mux/vscode-eslint-lsp",
    "--stdio"
  ],
  "command": "node",
  "languages": {
    "javascript": [
      ".js",
      ".mjs",
      ".cjs"
    ],
    "javascriptreact": [
      ".jsx"
    ],
    "typescript": [
      ".ts",
      ".mts",
      ".cts"
    ],
    "typescriptreact": [
      ".tsx"
    ]
  },
  "notifications": {
    "eslint/status": { "logLevel": "DEBUG" }
  },
  "npm": "@lsp-mux/vscode-eslint-lsp",
  "settings": {
    "nodePath": null,
    "problems": {
      "shortenToSingleLine": false
    },
    "rulesCustomizations": [],
    "run": "onType",
    "useESLintClass": true,
    "validate": "on",
    "workingDirectory": {
      "mode": "location"
    }
  },
  "transport": "stdio"
}
