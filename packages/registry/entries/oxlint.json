{
  "args": [
    "./node_modules/oxlint/bin/oxlint",
    "--lsp"
  ],
  "command": "node",
  "languages": {
    "javascript": [
      ".js",
      ".mjs",
      ".cjs"
    ],
    "javascriptreact": [
      ".jsx"
    ],
    "typescript": [
      ".ts",
      ".mts",
      ".cts"
    ],
    "typescriptreact": [
      ".tsx"
    ]
  },
  "npm": "oxlint",
  "transport": "stdio"
}
