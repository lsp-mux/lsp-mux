{
  "name": "lsp-proxy-registry",
  "version": "0.1.0",
  "description": "Server config registry for lsp-proxy",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "compile:ts": "gtb task compile:ts",
    "generate:entries": "node --experimental-strip-types scripts/generate-entries.ts",
    "lint:eslint": "gtb task lint:eslint",
    "pack:npm": "gtb task pack:npm",
    "typecheck:ts": "gtb task typecheck:ts"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "directory": "dist/source",
    "exports": {
      ".": "./src/index.js"
    },
    "linkDirectory": false
  }
}
