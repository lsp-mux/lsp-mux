{
  "name": "lsp-proxy",
  "version": "0.1.0",
  "description": "Multiplexing LSP proxy",
  "type": "module",
  "exports": {
    "./config": "./src/config.ts",
    "./logger": "./src/logger.ts"
  },
  "scripts": {
    "compile:ts": "gtb task compile:ts",
    "coverage:codecov:upload": "gtb task coverage:codecov:upload",
    "coverage:vitest:merge": "gtb task coverage:vitest:merge",
    "lint:eslint": "gtb task lint:eslint",
    "pack:npm": "gtb task pack:npm",
    "test:vitest:fast": "gtb task test:vitest:fast",
    "test:vitest:slow": "gtb task test:vitest:slow",
    "typecheck:ts": "gtb task typecheck:ts"
  },
  "dependencies": {
    "date-fns": "catalog:",
    "lsp-proxy-registry": "workspace:*",
    "picomatch": "catalog:",
    "valibot": "catalog:",
    "vscode-jsonrpc": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "directory": "dist/source",
    "exports": {
      "./config": "./src/config.js",
      "./logger": "./src/logger.js"
    },
    "linkDirectory": false
  }
}
