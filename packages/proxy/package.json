{
  "name": "lsp-proxy",
  "version": "0.1.0",
  "description": "Multiplexing LSP proxy",
  "type": "module",
  "main": "dist/source/main.js",
  "exports": {
    ".": "./dist/source/main.js",
    "./config": "./dist/source/config.js",
    "./logger": "./dist/source/logger.js"
  },
  "publishConfig": {
    "directory": "dist/source",
    "linkDirectory": false,
    "main": "main.js",
    "exports": {
      ".": "./main.js",
      "./config": "./config.js",
      "./logger": "./logger.js"
    }
  },
  "engines": {
    "node": ">=22.16"
  },
  "dependencies": {
    "lsp-proxy-registry": "workspace:*",
    "picomatch": "catalog:",
    "valibot": "catalog:",
    "vscode-jsonrpc": "catalog:"
  }
}
