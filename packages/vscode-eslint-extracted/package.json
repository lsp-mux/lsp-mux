{
  "name": "vscode-eslint-extracted",
  "version": "3.0.24",
  "description": "VS Code ESLint language server extracted from the vscode-eslint extension",
  "license": "MIT",
  "type": "module",
  "bin": {
    "vscode-eslint-extract": "bin/download.ts"
  },
  "publishConfig": {
    "directory": "dist/source",
    "linkDirectory": false,
    "bin": {
      "vscode-eslint-extract": "bin/download.js"
    },
    "scripts": {
      "postinstall": "node bin/download.js"
    }
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "postinstall": "node --experimental-strip-types bin/download.ts"
  },
  "dependencies": {
    "yauzl": "catalog:"
  },
  "devDependencies": {
    "@types/yauzl": "catalog:build"
  }
}
