{
  "name": "lsp-proxy-claude-code",
  "version": "0.1.0",
  "description": "Claude Code editor integration for lsp-proxy",
  "type": "module",
  "bin": {
    "generate-claude-plugin": "bin/generate-plugin.ts"
  },
  "scripts": {
    "compile:ts": "gtb task compile:ts",
    "lint:eslint": "gtb task lint:eslint",
    "pack:npm": "gtb task pack:npm",
    "typecheck:ts": "gtb task typecheck:ts"
  },
  "dependencies": {
    "lsp-proxy": "workspace:*"
  },
  "engines": {
    "node": ">=22.16"
  },
  "publishConfig": {
    "bin": {
      "generate-claude-plugin": "bin/generate-plugin.js"
    },
    "directory": "dist/source",
    "linkDirectory": false
  }
}
