{
  "name": "lsp-proxy-config-default",
  "version": "0.1.0",
  "description": "Default server configs (vtsls, eslint) for lsp-proxy",
  "type": "module",
  "files": [
    ".lsp-proxy.json",
    "README.md"
  ],
  "publishConfig": {
    "directory": "dist/source",
    "linkDirectory": false,
    "scripts": {
      "postinstall": "generate-claude-plugin"
    }
  },
  "scripts": {
    "generate-plugin": "generate-claude-plugin",
    "prepack": "cpy .lsp-proxy.json README.md dist/source/"
  },
  "dependencies": {
    "@lsp-mux/vscode-eslint-lsp": "catalog:lsp",
    "@vtsls/language-server": "catalog:lsp",
    "lsp-proxy-claude-code": "workspace:*",
    "oxlint": "catalog:lsp"
  }
}
