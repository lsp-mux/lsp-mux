{
  "name": "lsp-proxy-config-default",
  "version": "0.1.0",
  "description": "Default server configs (vtsls, eslint) for lsp-proxy",
  "type": "module",
  "files": [
    ".lsp-proxy.json",
    "README.md"
  ],
  "scripts": {
    "compile:ts": "cpy .lsp-proxy.json dist/source/",
    "generate-plugin": "generate-claude-plugin",
    "lint:eslint": "gtb task lint:eslint",
    "pack:npm": "gtb task pack:npm"
  },
  "dependencies": {
    "@lsp-mux/vscode-eslint-lsp": "catalog:",
    "@vtsls/language-server": "catalog:",
    "lsp-proxy-claude-code": "workspace:*",
    "oxlint": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "directory": "dist/source",
    "linkDirectory": false,
    "scripts": {
      "postinstall": "generate-claude-plugin"
    }
  }
}
