{
  "name": "claude-lsp-proxy",
  "version": "0.1.0",
  "description": "Multiplexing LSP proxy for Claude Code",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b && vitest run",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-plugin": "node --import tsx src/generate-plugin.ts"
  },
  "dependencies": {
    "@vtsls/language-server": "^0.3.0",
    "valibot": "^1.3.1",
    "vscode-jsonrpc": "^8.2.0"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
