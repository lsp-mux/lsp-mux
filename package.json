{
  "name": "lsp-proxy-root",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.16"
  },
  "scripts": {
    "build": "pnpm -r --if-present generate && concurrently -g pnpm:compile pnpm:prepare-publish pnpm:lint pnpm:test && pnpm generate-plugin && pnpm run pack",
    "compile": "tsc -b",
    "compile:watch": "tsc -b --watch",
    "generate-plugin": "pnpm -C packages/config-default generate-plugin",
    "lint": "eslint --max-warnings=0 .",
    "pack": "node --experimental-strip-types scripts/pack-all.ts",
    "prepare-publish": "node --experimental-strip-types scripts/prepare-publish.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "concurrently -g pnpm:compile:watch pnpm:test:watch"
  },
  "devDependencies": {
    "@faker-js/faker": "catalog:test",
    "@sinonjs/fake-timers": "catalog:test",
    "@stylistic/eslint-plugin": "catalog:lint",
    "@tsconfig/strictest": "catalog:build",
    "@types/node": "catalog:build",
    "@types/picomatch": "catalog:build",
    "@types/sinonjs__fake-timers": "catalog:build",
    "@vitest/coverage-v8": "catalog:test",
    "@vitest/eslint-plugin": "catalog:lint",
    "@vitest/ui": "catalog:test",
    "concurrently": "catalog:build",
    "console-fail-test": "catalog:test",
    "cpy-cli": "catalog:",
    "eslint": "catalog:lint",
    "eslint-import-resolver-typescript": "catalog:lint",
    "eslint-plugin-import-x": "catalog:lint",
    "eslint-plugin-n": "catalog:lint",
    "eslint-plugin-only-warn": "catalog:lint",
    "eslint-plugin-pnpm": "catalog:lint",
    "tsx": "catalog:build",
    "typescript": "catalog:build",
    "typescript-eslint": "catalog:lint",
    "valibot": "catalog:",
    "vitest": "catalog:test"
  }
}
